<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_wide_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="4dp"
    android:paddingEnd="2dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Normal content: days -->
    <LinearLayout
        android:id="@+id/widget_wide_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Day 0 -->
        <TextView
            android:id="@+id/widget_day_shift_0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Day 1 -->
        <TextView
            android:id="@+id/widget_day_shift_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Day 2 -->
        <TextView
            android:id="@+id/widget_day_shift_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Day 3 -->
        <TextView
            android:id="@+id/widget_day_shift_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Day 4 -->
        <TextView
            android:id="@+id/widget_day_shift_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Day 5 -->
        <TextView
            android:id="@+id/widget_day_shift_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Day 6 -->
        <TextView
            android:id="@+id/widget_day_shift_6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Not-configured message -->
    <TextView
        android:id="@+id/widget_wide_message"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Open ShiftTrack to set up your schedule"
        android:textColor="#43474E"
        android:textSize="12sp"
        android:visibility="gone" />

</FrameLayout>
