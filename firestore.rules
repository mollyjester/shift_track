rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// ShiftTrack — Firestore Security Rules
//
// Data model
//   users/{uid}                  Profile + spectators list
//   users/{uid}/shifts/{date}    Manual shift overrides
//   users/{uid}/leaves/{date}    Leave entries
//   users/{uid}/overtime/{date}  Overtime entries
//   invites/{token}              7-day single-use invite tokens (UUIDs)
//
// Role model
//   Owner     — the authenticated user whose uid matches the document path
//   Spectator — authenticated user whose uid appears in users/{uid}.spectators
//
// NOTE: Full atomic invite redemption (write to two documents in one
// transaction) can be hardened further by migrating to a Cloud Function.
// The rules below provide defence-in-depth for the current client-side approach.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reads the spectators array from the user document (only if it exists).
    function isSpectator(uid) {
      let userDoc = get(/databases/$(database)/documents/users/$(uid));
      return isSignedIn()
             && userDoc != null
             && request.auth.uid in userDoc.data.get("spectators", []);
    }

    // Returns true if the only field being changed on a user document is
    // "spectators", and the caller is appending exactly their own UID to an
    // existing list (never removing or adding someone else's).
    function isOnlyAddingSelfToSpectators() {
      let before = resource.data.get("spectators", []);
      let after  = request.resource.data.get("spectators", []);
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["spectators"])
             && after.size()    == before.size() + 1
             && after.hasAll(before)
             && after.hasAll([request.auth.uid]);
    }

    // Returns true if a new user document contains only a spectators array
    // with exactly the caller's own UID. (Fallback for invite redemption
    // when the host document doesn't exist yet.)
    function isNewDocWithOnlySelfAsSpectator() {
      return request.resource.data.keys().hasOnly(["spectators"])
             && request.resource.data.spectators.size() == 1
             && request.resource.data.spectators.hasAll([request.auth.uid]);
    }

    // ── Users ────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Owner: full access. Spectators: read-only.
      allow read:   if isOwner(uid) || isSpectator(uid);
      allow create: if isOwner(uid)
                    || (isSignedIn() && isNewDocWithOnlySelfAsSpectator());
      allow delete: if isOwner(uid);

      // Owner can update anything on their own document.
      // Any authenticated guest may append only their own UID to spectators
      // (enforced by isOnlyAddingSelfToSpectators).
      allow update: if isOwner(uid) || (isSignedIn() && isOnlyAddingSelfToSpectators());

      // ── Shift overrides ──────────────────────────────────────────────────
      match /shifts/{date} {
        allow read:  if isOwner(uid) || isSpectator(uid);
        allow write: if isOwner(uid)
                     && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
                     && request.resource.data.keys().hasOnly(["date", "shiftType", "isManualOverride", "note", "userId", "synced"])
                     && request.resource.data.shiftType in ["DAY", "NIGHT", "REST", "OFF"]
                     && request.resource.data.date is string
                     && request.resource.data.userId == uid;
      }

      // ── Leave entries ────────────────────────────────────────────────────
      match /leaves/{date} {
        allow read:  if isOwner(uid) || isSpectator(uid);
        allow write: if isOwner(uid)
                     && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
                     && request.resource.data.keys().hasOnly(["date", "leaveType", "halfDay", "note", "userId", "synced"])
                     && request.resource.data.leaveType in ["ANNUAL", "SICK", "PERSONAL", "UNPAID", "STUDY"]
                     && request.resource.data.date is string
                     && request.resource.data.userId == uid;
      }

      // ── Overtime entries ─────────────────────────────────────────────────
      match /overtime/{date} {
        allow read:  if isOwner(uid) || isSpectator(uid);
        allow write: if isOwner(uid)
                     && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
                     && request.resource.data.keys().hasOnly(["date", "hours", "note", "userId", "synced"])
                     && request.resource.data.hours is number
                     && request.resource.data.hours > 0
                     && request.resource.data.hours <= 24
                     && request.resource.data.date is string
                     && request.resource.data.userId == uid;
      }
      // ── Alarm overrides (experimental) ───────────────────────────────
      // [EXPERIMENTAL:ALARM]
      match /alarm_overrides/{date} {
        allow read:  if isOwner(uid);
        allow write: if isOwner(uid)
                     && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
                     && request.resource.data.keys().hasOnly(["date", "alarmCount", "intervalMinutes", "firstAlarmTime", "userId"])
                     && request.resource.data.alarmCount is int
                     && request.resource.data.alarmCount >= 1
                     && request.resource.data.alarmCount <= 10
                     && request.resource.data.intervalMinutes is int
                     && request.resource.data.firstAlarmTime is string
                     && request.resource.data.date is string
                     && request.resource.data.userId == uid;
      }    }

    // ── Invites ──────────────────────────────────────────────────────────────

    match /invites/{token} {
      // Any authenticated user can read an invite to check its status.
      allow read: if isSignedIn();

      // Only the host can create an invite, and only for themselves.
      // Validates: token matches document ID, claimed starts as false,
      // and the expiry is set in the future.
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.hostUid
                    && request.resource.data.get("claimed", false) == false
                    && request.resource.data.token == token
                    && request.resource.data.expiresAt > request.time.toMillis();

      // Any authenticated user can CLAIM an unclaimed, unexpired token.
      // The update must: flip claimed→true, set claimedBy to the requester,
      // and leave all other fields untouched.
      allow update: if isSignedIn()
                    && resource.data.claimed     == false
                    && resource.data.expiresAt    > request.time.toMillis()
                    && request.resource.data.claimed    == true
                    && request.resource.data.claimedBy  == request.auth.uid
                    && request.resource.data.hostUid    == resource.data.hostUid
                    && request.resource.data.token      == resource.data.token
                    && request.resource.data.expiresAt  == resource.data.expiresAt
                    && request.resource.data.createdAt  == resource.data.createdAt
                    && request.resource.data.hostDisplayName == resource.data.hostDisplayName;

      // Invite documents are never deleted from the client.
      allow delete: if false;
    }

    // Deny all other paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
